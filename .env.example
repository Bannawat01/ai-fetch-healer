# ai-fetch-healer configuration
# Priority order for OpenRouterProvider key resolution:
# 1) AI_HEALER_OPENROUTER_KEY
# 2) OPENROUTER_API_KEY
# 3) GEMINI_API_KEY (legacy fallback)

# Recommended primary key
AI_HEALER_OPENROUTER_KEY=your_openrouter_key_here

# Optional compatibility aliases (set only if needed)
# OPENROUTER_API_KEY=your_openrouter_key_here
# GEMINI_API_KEY=your_key_here