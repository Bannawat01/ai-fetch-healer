{
	"name": "ai-fetch-healer",
	"version": "1.0.2",
	"description": "Runtime API Auto-Healing Wrapper",
	"keywords": [
		"fetch",
		"ai",
		"gemini",
		"openrouter",
		"auto-healing",
		"api"
	],
	"author": "Bannawat Rattanarak",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Bannawat01/ai-fetch-healer.git"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/npm": "^13.1.5",
		"dotenv": "^17.4.2",
		"semantic-release": "^25.0.3",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	}
}
